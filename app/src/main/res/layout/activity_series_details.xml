<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101010">

    <!-- Fundo fullscreen -->
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.6"
        android:contentDescription="Imagem de Fundo" />

    <!-- Overlay escuro -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <!-- Container principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ===== SCROLL PRINCIPAL ===== -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- ===== POSTER + INFOS ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:orientation="horizontal">

                    <!-- Poster (ID da TV) -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="120dp"
                        android:layout_height="180dp"
                        app:cardBackgroundColor="#333333"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="4dp">

                        <ImageView
                            android:id="@+id/imgPoster"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop" />
                    </androidx.cardview.widget.CardView>

                    <!-- Coluna direita: título + metadados -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <!-- Logo título (ID da TV) -->
                        <ImageView
                            android:id="@+id/imgTitleLogo"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:layout_marginBottom="8dp"
                            android:scaleType="fitStart"
                            android:visibility="gone" />

                        <!-- Título (ID da TV) -->
                        <TextView
                            android:id="@+id/tvTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="Carregando..."
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <!-- Nota (ID da TV) -->
                        <TextView
                            android:id="@+id/tvRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:background="#FFC107"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:text="Nota: 0.0"
                            android:textColor="#000000"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <!-- Data lançamento (ID do celular) -->
                        <TextView
                            android:id="@+id/tvReleaseDate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#CCCCCC"
                            android:textSize="12sp" />

                        <!-- Gênero (ID da TV) -->
                        <TextView
                            android:id="@+id/tvGenre"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Gênero: ..."
                            android:textColor="#DDDDDD"
                            android:textSize="13sp" />

                        <!-- Badges técnicos (ID do celular) -->
                        <LinearLayout
                            android:id="@+id/llTechBadges"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="6dp"
                            android:visibility="gone">
                            <TextView android:id="@+id/tvBadge4k" android:text="4K" android:background="#33FFFFFF" android:paddingHorizontal="4dp" android:layout_marginEnd="4dp" android:textColor="#FFF" android:textSize="10sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
                            <TextView android:id="@+id/tvBadgeHdr" android:text="HDR" android:background="#33FFFFFF" android:paddingHorizontal="4dp" android:layout_marginEnd="4dp" android:textColor="#FFF" android:textSize="10sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
                            <TextView android:id="@+id/tvBadgeDolby" android:text="ATMOS" android:background="#33FFFFFF" android:paddingHorizontal="4dp" android:layout_marginEnd="4dp" android:textColor="#FFF" android:textSize="10sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
                            <TextView android:id="@+id/tvBadge51" android:text="5.1" android:background="#33FFFFFF" android:paddingHorizontal="4dp" android:layout_marginEnd="4dp" android:textColor="#FFF" android:textSize="10sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone"/>
                        </LinearLayout>

                        <!-- Elenco oculto legado (ID da TV) -->
                        <TextView
                            android:id="@+id/tvSeriesCast"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="gone"
                            android:text="Elenco antigo..." />

                        <!-- Elenco label (ID da TV) -->
                        <TextView
                            android:id="@+id/tvCast"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Elenco:"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <!-- RecyclerView elenco (ID da TV) -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerCast"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:orientation="horizontal"
                            android:focusable="true"
                            android:focusableInTouchMode="false"
                            android:descendantFocusability="afterDescendants"
                            android:nextFocusDown="@id/btnPlay"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                        <!-- Sinopse (ID da TV) -->
                        <TextView
                            android:id="@+id/tvPlot"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:ellipsize="end"
                            android:maxLines="5"
                            android:text="Sinopse..."
                            android:textColor="#EEEEEE"
                            android:textSize="13sp" />

                    </LinearLayout>
                </LinearLayout>

                <!-- ===== BARRA DE PROGRESSO (ID do celular) ===== -->
                <LinearLayout
                    android:id="@+id/layoutProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ProgressBar
                            android:id="@+id/progressBarMovie"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="4dp"
                            android:layout_weight="1"
                            android:progressDrawable="@drawable/progress_horizontal_disney" />

                        <TextView
                            android:id="@+id/tvTimeRemaining"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Restam 0h0min"
                            android:textColor="#BBBBBB"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== BOTÕES PLAY / RESUME / FAVORITO ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Assistir (ID da TV) -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnPlay"
                        android:layout_width="160dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_btn_white"
                        android:text="▶  ASSISTIR"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:focusable="true"
                        android:focusableInTouchMode="false"
                        android:nextFocusUp="@id/recyclerCast"
                        android:nextFocusRight="@id/btnResume"
                        android:nextFocusDown="@id/btnSeasonSelector" />

                    <!-- Continuar (ID da TV) -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnResume"
                        android:layout_width="160dp"
                        android:layout_height="50dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_btn_grey"
                        android:text="CONTINUAR"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:visibility="gone"
                        android:focusable="true"
                        android:focusableInTouchMode="false"
                        android:nextFocusLeft="@id/btnPlay"
                        android:nextFocusRight="@id/btnFavorite"
                        android:nextFocusDown="@id/btnSeasonSelector" />

                    <!-- Favorito (ID da TV) -->
                    <ImageButton
                        android:id="@+id/btnFavorite"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_marginStart="16dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/btn_star_big_off"
                        android:tint="#FFFFFF"
                        android:focusable="true"
                        android:focusableInTouchMode="false"
                        android:nextFocusLeft="@id/btnResume"
                        android:nextFocusDown="@id/btnSeasonSelector"
                        android:contentDescription="Favoritar" />

                </LinearLayout>

                <!-- ===== TÍTULO EPISÓDIOS (ID da TV) ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvEpisodesTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Episódios"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- ===== LISTA DE EPISÓDIOS (ID da TV) ===== -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerEpisodes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:descendantFocusability="afterDescendants"
                    android:nextFocusUp="@id/btnPlay"
                    android:nextFocusDown="@id/btnSeasonSelector" />

                <!-- ===== SUGESTÕES (ID do celular) ===== -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerSuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:nestedScrollingEnabled="false"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:descendantFocusability="afterDescendants"
                    android:nextFocusUp="@id/btnPlay" />

                <!-- IDs ocultos preservados para não quebrar o Kotlin -->
                <LinearLayout
                    android:id="@+id/btnDownloadArea"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:orientation="horizontal">
                    <ImageView android:id="@+id/imgDownloadState" android:layout_width="0dp" android:layout_height="0dp" />
                    <TextView android:id="@+id/tvDownloadState" android:layout_width="0dp" android:layout_height="0dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnDownloadSeason"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvCreatedBy"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btnCloseSeasonSelectorText"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- ===== SELETOR DE TEMPORADA FIXO NO RODAPÉ (ID da TV) ===== -->
        <TextView
            android:id="@+id/btnSeasonSelector"
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="16dp"
            android:background="#333333"
            android:clickable="true"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"
            android:text="Temporadas ▼"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:nextFocusUp="@id/recyclerEpisodes"
            android:nextFocusDown="@id/btnPlay" />

    </LinearLayout>

    <!-- ===== BOTÃO FECHAR (ID da TV) ===== -->
    <ImageButton
        android:id="@+id/btnCloseDetails"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="#FFFFFF"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:nextFocusDown="@id/btnPlay"
        android:contentDescription="Fechar" />

</FrameLayout>
