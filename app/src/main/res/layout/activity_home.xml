<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101010">

    <!-- ===== HEADER ===== -->
    <RelativeLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:paddingBottom="4dp"
        android:paddingHorizontal="16dp"
        android:elevation="10dp"
        android:translationZ="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="Para Você"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="180dp"
            android:layout_height="60dp"
            android:layout_centerInParent="true"
            android:src="@drawable/ic_launcher"
            android:scaleType="fitCenter"
            android:contentDescription="Logo"
            android:visibility="gone" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="220dp"
            android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/btnSettings"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_search_rounded"
            android:paddingStart="36dp"
            android:paddingEnd="8dp"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:hint="Buscar..."
            android:textColor="#FFFFFF"
            android:textColorHint="#AAAAAA"
            android:imeOptions="actionSearch"
            android:inputType="textNoSuggestions"
            android:maxLines="1"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusDown="@id/cardBanner"
            android:nextFocusRight="@id/btnSettings" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            app:tint="#FFFFFF"
            android:focusable="true"
            android:focusableInTouchMode="false"
            android:nextFocusDown="@id/cardBanner"
            android:nextFocusLeft="@id/etSearch" />

    </RelativeLayout>

    <!-- ===== SCROLL PRINCIPAL ===== -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== BANNER ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBanner"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#202020"
                app:cardElevation="0dp"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:clickable="true"
                android:nextFocusUp="@id/etSearch"
                android:nextFocusDown="@id/cardLiveTv">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/imgBanner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/gradient_black_bottom" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:padding="24dp"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/imgBannerLogo"
                            android:layout_width="240dp"
                            android:layout_height="90dp"
                            android:scaleType="fitCenter"
                            android:visibility="gone"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvBannerTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:shadowColor="#000000"
                            android:shadowRadius="6" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:id="@+id/tvBannerRating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⭐ 0.0"
                                android:textColor="#FFD700"
                                android:textStyle="bold"
                                android:textSize="14sp" />

                            <View android:layout_width="12dp" android:layout_height="1dp" />

                            <TextView
                                android:id="@+id/tvBannerOverview"
                                android:layout_width="350dp"
                                android:layout_height="wrap_content"
                                android:textColor="#CCCCCC"
                                android:textSize="14sp"
                                android:maxLines="1"
                                android:ellipsize="end" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/btnBannerPlay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/bg_search_rounded"
                            android:backgroundTint="#00C6FF"
                            android:paddingHorizontal="24dp"
                            android:paddingVertical="8dp"
                            android:text="ASSISTIR AGORA"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:visibility="visible"
                            android:focusable="true"
                            android:focusableInTouchMode="false"
                            android:nextFocusUp="@id/cardBanner"
                            android:nextFocusDown="@id/cardLiveTv" />

                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== BOTÕES PRINCIPAIS ===== -->
            <LinearLayout
                android:id="@+id/mainButtonsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp"
                android:weightSum="4"
                android:baselineAligned="false">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardLiveTv"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:nextFocusUp="@id/cardBanner"
                    android:nextFocusDown="@id/rvContinueWatching"
                    android:nextFocusRight="@id/cardMovies"
                    app:cardBackgroundColor="#252525">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:background="@drawable/bg_premium_blue">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AO VIVO"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMovies"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:nextFocusUp="@id/cardBanner"
                    android:nextFocusDown="@id/rvContinueWatching"
                    android:nextFocusLeft="@id/cardLiveTv"
                    android:nextFocusRight="@id/cardSeries"
                    app:cardBackgroundColor="#252525">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:background="@drawable/bg_premium_blue">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FILMES"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSeries"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:nextFocusUp="@id/cardBanner"
                    android:nextFocusDown="@id/rvContinueWatching"
                    android:nextFocusLeft="@id/cardMovies"
                    android:nextFocusRight="@id/cardKids"
                    app:cardBackgroundColor="#252525">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:background="@drawable/bg_premium_blue">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SÉRIES"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardKids"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="false"
                    android:nextFocusUp="@id/cardBanner"
                    android:nextFocusDown="@id/rvContinueWatching"
                    android:nextFocusLeft="@id/cardSeries"
                    app:cardBackgroundColor="#252525">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:background="@drawable/selector_kids_premium">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KIDS"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- ===== CONTINUAR ASSISTINDO ===== -->
            <TextView
                android:id="@+id/tvContinueWatching"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Continuar Assistindo"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvContinueWatching"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:paddingHorizontal="12dp"
                android:orientation="horizontal"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:descendantFocusability="afterDescendants"
                android:nextFocusUp="@id/cardLiveTv"
                android:nextFocusDown="@id/rvRecentlyAdded"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- ===== FILMES RECENTES ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filmes Recentes"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentlyAdded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:paddingHorizontal="12dp"
                android:orientation="horizontal"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:descendantFocusability="afterDescendants"
                android:nextFocusUp="@id/rvContinueWatching"
                android:nextFocusDown="@id/rvRecentSeries"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- ===== SÉRIES RECENTES ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Séries Recentes"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentSeries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:paddingHorizontal="12dp"
                android:paddingBottom="20dp"
                android:orientation="horizontal"
                android:focusable="true"
                android:focusableInTouchMode="false"
                android:descendantFocusability="afterDescendants"
                android:nextFocusUp="@id/rvRecentlyAdded"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
