<?xml version="1.0" encoding="utf-8"?>
<!-- layout_mini_player.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/miniPlayerContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#0D0D0D"
    android:visibility="gone">

    <!-- Linha de título + botão fechar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="#1A1A1A">

        <View
            android:layout_width="3dp"
            android:layout_height="14dp"
            android:background="#E50914"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvMiniChannelName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Canal"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvMiniHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Toque 2x para expandir"
            android:textColor="#88FFFFFF"
            android:textSize="10sp"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/btnMiniClose"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="✕"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Vídeo + EPG lado a lado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:orientation="horizontal">

        <!-- Mini vídeo -->
        <FrameLayout
            android:id="@+id/miniPlayerFrame"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:background="#000000"
            android:clickable="true"
            android:focusable="true">

            <androidx.media3.ui.PlayerView
                android:id="@+id/miniPlayerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:use_controller="false"
                app:surface_type="texture_view"
                app:resize_mode="fit"
                app:show_buffering="when_playing"
                android:keepScreenOn="true"/>

            <!-- Ícone de play overlay quando pausado -->
            <ImageView
                android:id="@+id/ivMiniPlayOverlay"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_media_play"
                android:alpha="0.7"
                android:visibility="gone"/>

            <ProgressBar
                android:id="@+id/miniLoading"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:indeterminateTint="#E50914"
                android:visibility="visible"/>
        </FrameLayout>

        <!-- EPG das próximas programações -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="#111111"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PROGRAMAÇÃO"
                android:textColor="#88FFFFFF"
                android:textSize="9sp"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <!-- Programa atual -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="#E50914"
                    android:layout_marginEnd="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvEpgNowTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agora"
                        android:textColor="#E50914"
                        android:textSize="9sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvEpgNow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Carregando..."
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Divisor -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF"
                android:layout_marginBottom="6dp"/>

            <!-- Próximo 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="5dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:background="#555555"
                    android:layout_marginEnd="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvEpgNext1Time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#888888"
                        android:textSize="9sp"/>

                    <TextView
                        android:id="@+id/tvEpgNext1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#CCCCCC"
                        android:textSize="11sp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Próximo 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="5dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:background="#555555"
                    android:layout_marginEnd="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvEpgNext2Time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#888888"
                        android:textSize="9sp"/>

                    <TextView
                        android:id="@+id/tvEpgNext2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#CCCCCC"
                        android:textSize="11sp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Próximo 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:background="#555555"
                    android:layout_marginEnd="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvEpgNext3Time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#888888"
                        android:textSize="9sp"/>

                    <TextView
                        android:id="@+id/tvEpgNext3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#CCCCCC"
                        android:textSize="11sp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
