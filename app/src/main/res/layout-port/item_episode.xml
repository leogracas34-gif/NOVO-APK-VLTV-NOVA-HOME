<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#111118"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical">

        <!-- Thumbnail do episódio com gradiente e play icon -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <androidx.cardview.widget.CardView
                android:layout_width="148dp"
                android:layout_height="84dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0A0A14">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Thumbnail HD -->
                    <ImageView
                        android:id="@+id/imgEpisodeThumb"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:color/darker_gray"/>

                    <!-- Gradiente escuro sobre thumbnail -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/gradient_episode_thumb"/>

                    <!-- Ícone play centralizado -->
                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play_circle"
                        android:alpha="0.85"
                        android:contentDescription="Play"/>

                    <!-- Barra de progresso na base -->
                    <ProgressBar
                        android:id="@+id/pbEpisodeProgress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:layout_gravity="bottom"
                        android:progressDrawable="@drawable/progress_horizontal_disney"
                        android:progressBackgroundTint="#44FFFFFF"
                        android:progress="0"
                        android:max="100"
                        android:visibility="gone"/>

                </FrameLayout>

            </androidx.cardview.widget.CardView>

        </FrameLayout>

        <!-- Informações do episódio -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="6dp">

            <!-- Número e título -->
            <TextView
                android:id="@+id/tvEpisodeTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:maxLines="2"
                android:ellipsize="end"
                android:letterSpacing="0.01"/>

            <!-- Sinopse -->
            <TextView
                android:id="@+id/tvEpisodePlot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textColor="#99FFFFFF"
                android:textSize="11sp"
                android:fontFamily="sans-serif"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.2"/>

        </LinearLayout>

        <!-- Botão download (escondido por padrão) -->
        <LinearLayout
            android:id="@+id/btnDownloadEpisode"
            android:layout_width="38dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imgDownloadIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/stat_sys_download"
                app:tint="#AAFFFFFF"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
