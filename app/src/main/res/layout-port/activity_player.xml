<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false">

    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="false"
        app:use_controller="true"
        app:surface_type="texture_view"
        app:resize_mode="fit"
        app:show_buffering="when_playing"
        android:keepScreenOn="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ── Barra superior ───────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical"
        android:background="#80000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/playerView"
        app:layout_constraintStart_toStartOf="@id/playerView"
        app:layout_constraintEnd_toEndOf="@id/playerView">

        <TextView
            android:id="@+id/tvChannelName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Título"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvNowPlaying"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Carregando programação..."
            android:textColor="#DDDDDD"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- ── Botão proporção ──────────────────────────────────────────────── -->
    <ImageButton
        android:id="@+id/btnAspect"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_aspect_ratio"
        android:focusable="false"
        android:focusableInTouchMode="false"
        app:tint="#FFFFFF"
        app:layout_constraintTop_toTopOf="@id/playerView"
        app:layout_constraintEnd_toEndOf="@id/playerView"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"/>

    <!-- ══════════════════════════════════════════════════════════════════
         CANTO INFERIOR DIREITO — estilo Netflix
         Empilhados de baixo para cima:
           [3] Pular Abertura
           [2] Pular Resumo
           [1] Próximo Episódio  ← mais próximo da borda inferior
         ══════════════════════════════════════════════════════════════════ -->

    <!-- [1] Próximo episódio ────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/nextEpisodeContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#CC000000"
        android:visibility="gone"
        android:descendantFocusability="afterDescendants"
        app:layout_constraintBottom_toBottomOf="@id/playerView"
        app:layout_constraintEnd_toEndOf="@id/playerView"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/tvNextEpisodeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Próximo episódio em 60s"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnPlayNextEpisode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Ir para o próximo"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#D32F2F"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusUp="@id/btnPlayNextEpisode"
            android:nextFocusDown="@id/btnPlayNextEpisode"
            android:nextFocusLeft="@id/btnPlayNextEpisode"
            android:nextFocusRight="@id/btnPlayNextEpisode"/>
    </LinearLayout>

    <!-- [2] Pular Resumo — acima do próximo episódio ────────────────────── -->
    <Button
        android:id="@+id/btnSkipRecap"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:text="⏭  Pular Resumo"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textAllCaps="false"
        android:backgroundTint="#BB000000"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:visibility="gone"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:layout_constraintEnd_toEndOf="@id/playerView"
        app:layout_constraintBottom_toTopOf="@id/nextEpisodeContainer"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="8dp"/>

    <!-- [3] Pular Abertura — acima do pular resumo ──────────────────────── -->
    <Button
        android:id="@+id/btnSkipIntro"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:text="⏭  Pular Abertura"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textAllCaps="false"
        android:backgroundTint="#BB000000"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:visibility="gone"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:layout_constraintEnd_toEndOf="@id/playerView"
        app:layout_constraintBottom_toTopOf="@id/btnSkipRecap"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="8dp"/>

    <!-- ── Loading central ───────────────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
