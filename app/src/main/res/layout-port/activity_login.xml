<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080808">

    <!-- Fundo escuro com imagem de poster -->
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_poster_placeholder"
        android:tint="#CC000510"
        android:alpha="0.6"
        android:tintMode="src_over"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Overlay gradiente -->
    <View
        android:id="@+id/vGradientOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_radial_neon_glow"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Card central -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="32dp"
        android:paddingBottom="36dp"
        android:background="@drawable/bg_login_card_premium"
        android:elevation="40dp"
        app:layout_constraintWidth_max="400dp"
        app:layout_constraintWidth_percent="0.86"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo block -->
        <LinearLayout
            android:id="@+id/layoutLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VLTV"
                    android:textColor="#FFFFFF"
                    android:textSize="52sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"
                    android:letterSpacing="0.10"
                    android:shadowColor="#99E50914"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="18" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+"
                    android:textColor="#E50914"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"
                    android:shadowColor="#CCE50914"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="16" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENTRETENIMENTO PREMIUM"
                android:textColor="#55FFFFFF"
                android:textSize="8sp"
                android:letterSpacing="0.30"
                android:layout_marginTop="2dp" />

            <View
                android:layout_width="36dp"
                android:layout_height="1dp"
                android:background="@drawable/bg_gold_divider"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="2dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACESSE SUA CONTA"
            android:textColor="#44FFFFFF"
            android:textSize="9sp"
            android:letterSpacing="0.22"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/layoutLogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Campo Usuário -->
        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_login_input_premium"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:hint="  Usuário"
            android:textColor="#FFFFFF"
            android:textColorHint="#55FFFFFF"
            android:textSize="14sp"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:singleLine="true"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Campo Senha -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_login_input_premium"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:hint="  Senha"
            android:inputType="textPassword"
            android:textColor="#FFFFFF"
            android:textColorHint="#55FFFFFF"
            android:textSize="14sp"
            android:imeOptions="actionDone"
            android:singleLine="true"
            app:layout_constraintTop_toBottomOf="@id/etUsername"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botão ENTRAR -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_login_neon"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            android:text="ENTRAR"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:letterSpacing="0.18"
            android:textStyle="bold"
            android:elevation="8dp"
            android:stateListAnimator="@null"
            android:focusable="true"
            android:clickable="true"
            app:layout_constraintTop_toBottomOf="@id/etPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ProgressBar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:visibility="gone"
            android:indeterminateTint="#E50914"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/btnLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Rodapé -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ACESSO SEGURO · VLTV+"
        android:textColor="#1AFFFFFF"
        android:textSize="8sp"
        android:letterSpacing="0.20"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
