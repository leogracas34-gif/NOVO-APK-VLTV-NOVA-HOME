<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060610">

    <!-- ── Background full-height com parallax visual ── -->
    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="480dp"
        android:scaleType="centerCrop"
        android:alpha="0.92"/>

    <!-- Gradiente triplo sobre o background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="480dp"
        android:background="@drawable/bg_details_scrim"/>

    <!-- ── Scroll principal ── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="88dp">

            <!-- Espaço para o background aparecer -->
            <View android:layout_width="match_parent" android:layout_height="180dp"/>

            <!-- Logo do título -->
            <ImageView
                android:id="@+id/imgTitleLogo"
                android:layout_width="260dp"
                android:layout_height="100dp"
                android:layout_gravity="center_horizontal"
                android:scaleType="fitCenter"
                android:visibility="gone"/>

            <!-- Título texto fallback -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:gravity="center"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:shadowColor="#CC000000"
                android:shadowRadius="8"
                android:letterSpacing="0.01"/>

            <!-- Metadados: avaliação + ano + qualidade -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rating_badge"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="2dp"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:textColor="#AAFFFFFF"
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="HD"
                    android:background="@drawable/bg_tag_hd"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- Gênero -->
            <TextView
                android:id="@+id/tvGenre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:textColor="#88FFFFFF"
                android:textSize="11sp"/>

            <!-- Barra de progresso -->
            <LinearLayout
                android:id="@+id/layoutProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="22dp"
                android:layout_marginTop="14dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ProgressBar
                        android:id="@+id/progressBarMovie"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="3dp"
                        android:layout_weight="1"
                        android:progressDrawable="@drawable/progress_horizontal_disney"
                        android:progressBackgroundTint="#33FFFFFF"/>

                    <TextView
                        android:id="@+id/tvTimeRemaining"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="#88FFFFFF"
                        android:textSize="10sp"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnRestartAction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="6dp"
                    android:layout_gravity="center_horizontal"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:visibility="gone">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_rotate"
                        app:tint="#88FFFFFF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Assistir do início"
                        android:textColor="#88FFFFFF"
                        android:textSize="11sp"
                        android:layout_marginStart="5dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Botão ASSISTIR principal — branco sólido estilo Netflix -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPlay"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_btn_white"
                android:text="▶  ASSISTIR"
                android:textColor="#000000"
                android:textSize="15sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"/>

            <!-- Botão CONTINUAR (oculto por padrão) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnResume"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>

            <!-- Ações secundárias: Reiniciar / Trailer / Favoritar / Baixar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="8dp">

                <LinearLayout
                    android:id="@+id/btnRestartActionAlt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@android:drawable/ic_menu_rotate" app:tint="#CCFFFFFF"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="REINICIAR" android:textColor="#AAFFFFFF" android:textSize="9sp" android:layout_marginTop="4dp" android:letterSpacing="0.05"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnTrailerAction"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_details_trailer"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TRAILER" android:textColor="#AAFFFFFF" android:textSize="9sp" android:layout_marginTop="4dp" android:letterSpacing="0.05"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnFavoriteLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageButton
                        android:id="@+id/btnFavorite"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_details_add"
                        app:tint="#CCFFFFFF"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MINHA LISTA" android:textColor="#AAFFFFFF" android:textSize="9sp" android:layout_marginTop="4dp" android:letterSpacing="0.05"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnDownloadAction"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView android:id="@+id/imgDownloadState" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_details_download"/>
                    <TextView android:id="@+id/tvDownloadState" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BAIXAR" android:textColor="#AAFFFFFF" android:textSize="9sp" android:layout_marginTop="4dp" android:letterSpacing="0.05"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Sinopse -->
            <TextView
                android:id="@+id/tvPlot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="16dp"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.4"
                android:maxLines="4"
                android:ellipsize="end"/>

            <!-- Elenco -->
            <TextView
                android:id="@+id/tvCast"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="8dp"
                android:textColor="#88FFFFFF"
                android:textSize="11sp"/>

            <!-- Divisor -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="18dp"
                android:layout_marginTop="16dp"
                android:background="#1AFFFFFF"/>

            <!-- Abas: Sugestões / Extras / Detalhes -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayoutDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#00000000"
                app:tabIndicatorColor="#FFFFFF"
                app:tabIndicatorHeight="2dp"
                app:tabSelectedTextColor="#FFFFFF"
                app:tabTextColor="#55FFFFFF"
                app:tabMode="fixed"
                app:tabTextAppearance="@android:style/TextAppearance.Small">
                <com.google.android.material.tabs.TabItem android:text="SUGESTÕES"/>
                <com.google.android.material.tabs.TabItem android:text="EXTRAS"/>
                <com.google.android.material.tabs.TabItem android:text="DETALHES"/>
            </com.google.android.material.tabs.TabLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF"/>

            <!-- Conteúdo das abas -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerSuggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="visible"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerEpisodes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"/>

                <LinearLayout
                    android:id="@+id/layoutTabDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="18dp"
                    android:paddingTop="8dp"
                    android:visibility="gone">

                    <TextView android:id="@+id/tvDetailFullTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="6dp"/>
                    <TextView android:id="@+id/tvDetailFullPlot" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#AAFFFFFF" android:textSize="12sp" android:lineSpacingMultiplier="1.4" android:layout_marginBottom="14dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Duração" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvDetailDuration" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#88FFFFFF" android:textSize="11sp" android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lançamento" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvDetailReleaseDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#88FFFFFF" android:textSize="11sp" android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gênero" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvDetailGenre" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#88FFFFFF" android:textSize="11sp" android:layout_marginBottom="8dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Direção" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="11sp"/>
                    <TextView android:id="@+id/tvDetailDirector" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#88FFFFFF" android:textSize="11sp"/>

                </LinearLayout>

            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Views ocultas mantidas para compatibilidade com o código Kotlin -->
    <ImageView android:id="@+id/imgPoster" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <Button android:id="@+id/btnSettings" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/tvEpisodesTitle" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <LinearLayout android:id="@+id/btnDownloadArea" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:orientation="vertical">
        <ImageView android:id="@+id/imgDownloadState2" android:layout_width="0dp" android:layout_height="0dp"/>
        <TextView android:id="@+id/tvDownloadState2" android:layout_width="0dp" android:layout_height="0dp"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerCast" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        app:itemIconTint="@drawable/bottom_nav_tint"
        app:itemTextColor="@drawable/bottom_nav_tint"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"/>

</FrameLayout>
