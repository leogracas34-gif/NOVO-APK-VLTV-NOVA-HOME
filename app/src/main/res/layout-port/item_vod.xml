<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="118dp"
    android:layout_height="176dp"
    android:layout_marginHorizontal="5dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#0D0D18"
    android:clickable="true"
    android:focusable="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Poster principal — HD centerCrop -->
        <ImageView
            android:id="@+id/imgPoster"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"/>

        <!-- Gradiente duplo: sutil no topo, denso na base -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_vod_card"/>

        <!-- Logo do título via TMDB (substitui texto quando disponível) -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="8dp"
            android:layout_marginHorizontal="6dp"
            android:scaleType="fitCenter"
            android:visibility="invisible"/>

        <!-- Nome texto (fallback quando não tem logo) -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:paddingStart="7dp"
            android:paddingEnd="7dp"
            android:paddingBottom="7dp"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:fontFamily="sans-serif-condensed"
            android:shadowColor="#CC000000"
            android:shadowRadius="5"
            android:shadowDx="0"
            android:shadowDy="1"
            android:gravity="start"
            android:visibility="gone"/>

        <!-- Ícone de download — canto superior direito, pequeno e discreto -->
        <ImageView
            android:id="@+id/imgDownload"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:background="@drawable/bg_download_badge"
            android:padding="5dp"
            android:src="@drawable/ic_download"
            android:scaleType="centerInside"
            android:visibility="gone"/>

        <!-- Borda de foco sutil — aparece ao focar (TV/controle) -->
        <View
            android:id="@+id/viewFocusBorder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_card_focus_border"
            android:visibility="invisible"/>

    </FrameLayout>

</androidx.cardview.widget.CardView>
